export type Tokens = typeof tokens;

// Utility function to get token values
export const getToken = <T extends keyof Tokens>(category: T, key: string): any => {
  const categoryTokens = tokens[category] as any;
  return categoryTokens[key];
};

// Utility function to get nested token values
export const getNestedToken = <T extends keyof Tokens>(
  category: T,
  parentKey: string,
  childKey: string
): any => {
  const categoryTokens = tokens[category] as any;
  return categoryTokens[parentKey]?.[childKey];
};

export default tokens;