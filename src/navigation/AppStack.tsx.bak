 * Includes swipe gestures for tab navigation
 */
export function GestureAwareAppStack() {
  const { app } = useAppStore();
  
  useScreenTracking();

  // Handle swipe gestures for tab navigation
  const handleSwipeGesture = useCallback((direction: 'left' | 'right') => {
    console.log(`Swipe gesture detected: ${direction}`);
    // Implement tab switching logic based on swipe
  }, []);

  return (
    <Tab.Navigator
      initialRouteName={ROUTE_NAMES.APP.HOME_STACK}
      screenOptions={{
        headerShown: false,
        ...NAVIGATION_CONFIG.TAB_BAR_OPTIONS,
        tabBarStyle: {
          ...NAVIGATION_CONFIG.TAB_BAR_OPTIONS.style,
          backgroundColor: app.theme === 'dark' ? '#1C1C1E' : '#FFFFFF',
          borderTopColor: app.theme === 'dark' ? '#38383A' : '#E5E5E7',
        },
      }}
      sceneContainerStyle={{
        backgroundColor: app.theme === 'dark' ? '#000000' : '#FFFFFF',
      }}
    >
      <Tab.Screen
        name={ROUTE_NAMES.APP.HOME_STACK}
        component={HomeStack}
        options={{
          tabBarIcon: ({ focused, color, size }) => (
            <TabIcon name="home" focused={focused} color={color} size={size} />
          ),
          tabBarLabel: 'Home',
        }}
      />
      
      <Tab.Screen
        name={ROUTE_NAMES.APP.WARDROBE_STACK}
        component={WardrobeStack}
        options={{
          tabBarIcon: ({ focused, color, size }) => (
            <TabIcon name="wardrobe" focused={focused} color={color} size={size} />
          ),
          tabBarLabel: 'Wardrobe',
        }}
      />
      
      <Tab.Screen
        name={ROUTE_NAMES.APP.STYLING_STACK}
        component={StylingStack}
        options={{
          tabBarIcon: ({ focused, color, size }) => (
            <TabIcon name="styling" focused={focused} color={color} size={size} />
          ),
          tabBarLabel: 'Styling',
        }}
      />
      
      <Tab.Screen
        name={ROUTE_NAMES.APP.PROFILE_STACK}
        component={ProfileStack}
        options={{
          tabBarIcon: ({ focused, color, size }) => (
            <TabIcon name="profile" focused={focused} color={color} size={size} />
          ),
          tabBarLabel: 'Profile',
        }}
      />
    </Tab.Navigator>
  );
}

export default AppStack;