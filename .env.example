# Environment Configuration
EXPO_PUBLIC_ENVIRONMENT=development

# Firebase Configuration - Production
EXPO_PUBLIC_FIREBASE_API_KEY=your_production_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=styleai-prod.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=styleai-prod
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=styleai-prod.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Configuration - Staging
EXPO_PUBLIC_FIREBASE_API_KEY_STAGING=your_staging_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN_STAGING=styleai-staging.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID_STAGING=styleai-staging
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET_STAGING=styleai-staging.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_STAGING=your_staging_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID_STAGING=your_staging_app_id

# Gemini AI Configuration
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# Analytics & Monitoring
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token