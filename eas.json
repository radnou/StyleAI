{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m1-medium"
      },
      "android": {
        "resourceClass": "medium"
      }
    },
    "staging": {
      "extends": "production",
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "staging"
      },
      "ios": {
        "bundleIdentifier": "com.styleai.staging",
        "buildConfiguration": "Release"
      },
      "android": {
        "buildType": "apk",
        "package": "com.styleai.staging"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_ENVIRONMENT": "production"
      },
      "ios": {
        "bundleIdentifier": "com.styleai.app",
        "buildConfiguration": "Release",
        "resourceClass": "m1-medium",
        "simulator": false,
        "autoIncrement": true
      },
      "android": {
        "buildType": "aab",
        "package": "com.styleai.app",
        "resourceClass": "medium",
        "autoIncrement": true
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "bundleIdentifier": "com.styleai.preview"
      },
      "android": {
        "buildType": "apk",
        "package": "com.styleai.preview"
      }
    }
  },
  "submit": {
    "staging": {
      "ios": {
        "appleId": "your-apple-id@email.com",
        "ascAppId": "your-staging-asc-app-id",
        "appleTeamId": "your-apple-team-id"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account-staging.json",
        "track": "internal"
      }
    },
    "production": {
      "ios": {
        "appleId": "your-apple-id@email.com",
        "ascAppId": "your-production-asc-app-id",
        "appleTeamId": "your-apple-team-id"
      },
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      }
    }
  }
}